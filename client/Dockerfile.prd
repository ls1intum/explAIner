# Multi-stage build for production
# Stage 1: Build
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# API URL for client bundle (Render passes from env; default for local Docker build)
ARG NEXT_PUBLIC_API_URL=http://localhost:3001
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Soft access-gate token. Middleware runs in the Edge runtime, which only sees
# env vars present at build time, so the token must be inlined here (not at
# runtime). Leave empty to disable the gate. See client/src/middleware.ts.
ARG SITE_ACCESS_TOKEN
ENV SITE_ACCESS_TOKEN=$SITE_ACCESS_TOKEN

# Build the Next.js application
RUN npm run build

# Stage 2: Production
FROM node:20-alpine

WORKDIR /app

# Set NODE_ENV to production
ENV NODE_ENV=production

# Copy package files
COPY package*.json ./

# Install only production dependencies
RUN npm ci --only=production

# Copy built application from builder stage
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/next.config.* ./

# Expose port
EXPOSE 3000

# Start the application
CMD ["npm", "start"]
