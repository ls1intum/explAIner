################################################################################
# SERVER
################################################################################

# General
SERVER_PORT=4001

# Database
DB_USER=your-db-username        # customize this how you like :)
DB_PASSWORD=your-db-password    # customize this how you like :)
DB_NAME=your-db-name            # customize this how you like :)

# LLM
ANTHROPIC_API_KEY=your-anthropic-api-key    # IMPORTANT: you must add your api-key here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929





################################################################################
# CLIENT
################################################################################

# General
CLIENT_PORT=4000
CLIENT_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4001

# Soft access gate: when set, the whole site is hidden behind this token.
# Reachable via ?token=<value> in embed URLs or typed on the access page.
# In production set this in the GitHub "Production" environment, not here.
SITE_ACCESS_TOKEN=
