################################################################################
# SERVER
################################################################################

# General
SERVER_PORT=3001

# Database
DB_USER=your-db-username        # customize this how you like :)
DB_PASSWORD=your-db-password    # customize this how you like :)
DB_NAME=your-db-name            # customize this how you like :)

# LLM (logos / OpenAI-compatible)
LLM_API_KEY=your-logos-api-key              # IMPORTANT: you must add your api-key here
LLM_BASE_URL=https://logos.aet.cit.tum.de/v1
LLM_MODEL=openai/gpt-oss-120b





################################################################################
# CLIENT
################################################################################

# General
CLIENT_PORT=3000
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional soft access gate (see client/src/middleware.ts). Leave empty = open.
SITE_ACCESS_TOKEN=
